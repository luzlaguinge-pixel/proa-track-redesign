# Get these from your Humand admin
HUMAND_CLIENT_ID=your-client-id
HUMAND_CLIENT_SECRET=your-client-secret
HUMAND_API_URL=https://api-prod.humand.co
POSTGREST_BASE_URL=https://views-cx.humand.co
GITHUB_TOKEN=github-token

# Login — Janus cx-login (serverless only, never VITE_*)
# JANUS_URL is a hardcoded prod default — do not override unless you know exactly why.
JANUS_URL=https://api-prod.humand.co/api/v1/janus
JANUS_INSTANCE_ID=your-instance-id
SESSION_SECRET=replace-with-32-plus-random-chars
